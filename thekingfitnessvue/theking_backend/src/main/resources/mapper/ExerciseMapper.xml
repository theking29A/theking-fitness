<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.theking.theking_backend.mapper.ExerciseMapper">

    <resultMap id="ExerciseResultMap" type="com.theking.theking_backend.entity.Exercise">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="description" column="description"/>
        <result property="category" column="category"/>
        <result property="targetMuscles" column="target_muscles"/>
        <result property="difficulty" column="difficulty"/>
        <result property="equipment" column="equipment"/>
        <result property="videoUrl" column="video_url"/>
        <result property="imageUrl" column="image_url"/>
        <result property="tips" column="tips"/>
        <result property="caloriesPerMin" column="calories_per_min"/>
        <result property="durationSeconds" column="duration_seconds"/>
        <result property="status" column="status"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <!-- 动态搜索 + 分页 -->
    <select id="searchByKeywordPage" resultMap="ExerciseResultMap">
        SELECT * FROM exercises
        <where>
            status = 1
            <if test="keyword != null and keyword != ''">
                AND (name LIKE CONCAT('%', #{keyword}, '%')
                OR description LIKE CONCAT('%', #{keyword}, '%')
                OR target_muscles LIKE CONCAT('%', #{keyword}, '%'))
            </if>
        </where>
    </select>

    <!-- 按分类和状态分页查询 -->
    <select id="findByCategoryAndStatusPage" resultMap="ExerciseResultMap">
        SELECT * FROM exercises
        WHERE category = #{category} AND status = #{status}
    </select>

    <!-- 按状态分页查询 -->
    <select id="findByStatusOrderBySortOrderAscPage" resultMap="ExerciseResultMap">
        SELECT * FROM exercises WHERE status = #{status} ORDER BY sort_order ASC
    </select>

</mapper>
